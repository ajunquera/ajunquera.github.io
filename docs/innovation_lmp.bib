@article{junquera2024b,
  title = {Las Pol\'iticas Activas de Empleo En El Marco de Las Pol\'iticas de Empleo},
  author = {Junquera, {\'A}lvaro F.},
  year = 2024,
  month = dec,
  journal = {Anuario IET de Trabajo y Relaciones Laborales},
  volume = {10},
  pages = {e124},
  issn = {2339-5753},
  doi = {10.5565/rev/aiet.124},
  urldate = {2026-03-22},
  abstract = {En este trabajo desarrollamos una conceptualizaci\'on de las pol\'iticas activas de empleo como un subconjunto de las pol\'iticas de empleo. A partir de una revisi\'on de la literatura, elaboramos una tipolog\'ia de herramientas usadas en los dise\~nos de las pol\'iticas activas de empleo y repasamos dos procedimientos para la conformaci\'on de grupos diana en estas pol\'iticas. Atendiendo a sus herramientas, obtenemos cuatro tipos de pol\'iticas activas de empleo seg\'un sus objetivos y medios: servicios de b\'usqueda de empleo, formaci\'on de adultos, subvenciones al empleo y subvenciones a la movilidad geogr\'afica. Atendiendo a la creaci\'on de grupos diana, describimos un procedimiento basado en la estimaci\'on del efecto de las intervenciones y otro procedimiento fundamentado en la predicci\'on del estado del desempleado al cabo de un a\~no. Una delimitaci\'on m\'as precisa de las pol\'iticas activas de empleo como la que presentamos permitir\'ia una comparaci\'on m\'as consistente de evaluaciones de impacto y facilitar\'ia la transferencia de conocimiento.},
  copyright = {https://creativecommons.org/licenses/by/4.0},
  file = {C:\Users\afernan5\Zotero\storage\I397LDIM\Junquera - 2024 - Las políticas activas de empleo en el marco de las políticas de empleo.pdf}
}

